        varchar NAME_
        varchar KEY_
        integer VERSION_
        varchar DEPLOYMENT_ID_ FK
        varchar RESOURCE_NAME_
        varchar DGRM_RESOURCE_NAME_
        varchar TENANT_ID_
    }

    %% =========================================================
    %% RUNTIME (RU) — active process/case/job state
