%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#f5f5f5', 'primaryBorderColor': '#999'}}}%%
erDiagram
    classDef default fill:#f5f5f5,stroke:#999,stroke-width:1px
    classDef ge fill:#d0e4f7,stroke:#4a6fa5,stroke-width:2px
    classDef re fill:#d4edda,stroke:#2e8b57,stroke-width:2px
    classDef ru fill:#fff3cd,stroke:#b8860b,stroke-width:2px
    classDef hi fill:#fde8cc,stroke:#cd853f,stroke-width:2px
    classDef id fill:#e8d5f5,stroke:#7b5ea7,stroke-width:2px

    %% =========================================================
    %% GENERAL (GE) — infrastructure tables
    %% =========================================================

    ACT_GE_PROPERTY {
        varchar NAME_ PK
        varchar VALUE_
        integer REV_
    }

    ACT_GE_BYTEARRAY {
        varchar ID_ PK
        integer REV_
        varchar NAME_
        varchar DEPLOYMENT_ID_ FK
        bytea   BYTES_
        boolean GENERATED_
        varchar TENANT_ID_
        integer TYPE_
        timestamp CREATE_TIME_
        varchar ROOT_PROC_INST_ID_
        timestamp REMOVAL_TIME_
    }

    ACT_GE_SCHEMA_LOG {
        varchar   ID_ PK
        timestamp TIMESTAMP_
        varchar   VERSION_
    }

    %% =========================================================
    %% REPOSITORY (RE) — definitions and deployments
    %% =========================================================

    ACT_RE_DEPLOYMENT {
        varchar   ID_ PK
        varchar   NAME_
        timestamp DEPLOY_TIME_
        varchar   SOURCE_
        varchar   TENANT_ID_
    }

    ACT_RE_PROCDEF {
        varchar ID_ PK
        integer REV_
        varchar CATEGORY_
        varchar NAME_
        varchar KEY_
        integer VERSION_
        varchar DEPLOYMENT_ID_ FK
        varchar RESOURCE_NAME_
        varchar DGRM_RESOURCE_NAME_
        boolean HAS_START_FORM_KEY_
        integer SUSPENSION_STATE_
        varchar TENANT_ID_
        varchar VERSION_TAG_
        integer HISTORY_TTL_
        boolean STARTABLE_
    }

    ACT_RE_CAMFORMDEF {
        varchar ID_ PK
        integer REV_
        varchar KEY_
        integer VERSION_
        varchar DEPLOYMENT_ID_ FK
        varchar RESOURCE_NAME_
        varchar TENANT_ID_
    }

    ACT_RE_CASE_DEF {
        varchar ID_ PK
