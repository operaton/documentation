        varchar   ROOT_PROC_INST_ID_
        timestamp REMOVAL_TIME_
    }

    ACT_HI_DEC_OUT {
        varchar   ID_ PK
        varchar   DEC_INST_ID_ FK
        varchar   CLAUSE_ID_
        varchar   CLAUSE_NAME_
        varchar   RULE_ID_
        integer   RULE_ORDER_
        varchar   VAR_NAME_
        varchar   VAR_TYPE_
        varchar   BYTEARRAY_ID_
        double    DOUBLE_
        bigint    LONG_
        varchar   TEXT_
        varchar   TEXT2_
        varchar   TENANT_ID_
        timestamp CREATE_TIME_
        varchar   ROOT_PROC_INST_ID_
        timestamp REMOVAL_TIME_
    }

    %% =========================================================
    %% IDENTITY (ID) — users, groups, tenants
    %% =========================================================

    ACT_ID_GROUP {
        varchar ID_ PK
        integer REV_
        varchar NAME_
        varchar TYPE_
    }

    ACT_ID_MEMBERSHIP {
        varchar USER_ID_ PK
        varchar GROUP_ID_ PK
    }

    ACT_ID_USER {
        varchar   ID_ PK
        integer   REV_
        varchar   FIRST_
        varchar   LAST_
        varchar   EMAIL_
        varchar   PWD_
        varchar   SALT_
        timestamp LOCK_EXP_TIME_
        integer   ATTEMPTS_
        varchar   PICTURE_ID_
    }

    ACT_ID_INFO {
        varchar ID_ PK
        integer REV_
        varchar USER_ID_
        varchar TYPE_
        varchar KEY_
        varchar VALUE_
        bytea   PASSWORD_
        varchar PARENT_ID_
    }

    ACT_ID_TENANT {
        varchar ID_ PK
        integer REV_
        varchar NAME_
    }

    ACT_ID_TENANT_MEMBER {
        varchar ID_ PK
        varchar TENANT_ID_ FK
        varchar USER_ID_ FK
        varchar GROUP_ID_ FK
    }

